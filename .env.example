# 법제처 국가법령정보 공동활용 API 인증값입니다.
# 전체 URL이 아니라 OC/API 인증값만 입력하세요.
LAW_API_KEY=
LAW_API_OC=

# 관리자 페이지 로그인 비밀번호입니다. 운영에서는 길고 예측하기 어려운 값으로 설정하세요.
ADMIN_PASSWORD=

# 관리자 세션 서명용 비밀값입니다. 운영에서는 ADMIN_PASSWORD와 다른 32자 이상의 랜덤 문자열을 권장합니다.
ADMIN_SESSION_SECRET=

# 향후 Supabase/PostgreSQL 영구 저장소를 연결할 때 사용할 접속 문자열입니다.
DATABASE_URL=

# 운영 도메인을 쉼표로 구분해 입력합니다. 예: https://your-app.vercel.app,https://hr.example.com
ALLOWED_ORIGINS=
