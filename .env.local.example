# 법제처 국가법령정보 공동활용 API 인증값입니다.
# 전체 URL이 아니라 OC/API 인증값만 입력하세요.
LAW_API_KEY=your-law-api-key
LAW_API_OC=your-law-api-key

# 관리자 페이지 로그인/세션 설정입니다.
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-to-a-long-random-secret

# 향후 Supabase/PostgreSQL 영구 저장소를 연결할 때 사용합니다.
DATABASE_URL=

# 로컬 개발 중 CSRF 출처 검증 허용 목록입니다.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 판례 상세 API 기준 URL:
# https://www.law.go.kr/DRF/lawService.do?target=prec
